{
  "name": "@forge/canvas-vue",
  "version": "1.0.0-alpha.4",
  "description": "Canvas registry + AG-UI streaming for forge-generated Vue applications.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.51",
    "@ag-ui/core": "^0.0.51",
    "marked": "^15.0.0",
    "dompurify": "^3.2.0"
  },
  "devDependencies": {
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0",
    "vite": "^6.3.0",
    "vitest": "^2.1.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/forge-project/forge.git",
    "directory": "packages/canvas-vue"
  }
}

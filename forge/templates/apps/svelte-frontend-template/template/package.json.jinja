{
  "name": "{{ project_slug }}",
  "private": true,
  "version": "{{ version }}",
  "type": "module",
  "scripts": {
    {%- if include_openapi %}
    "codegen": "openapi-ts",
    "predev": "npm run codegen",
    {%- endif %}
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint ."
  },
  "dependencies": {
    {%- if include_chat %}
    "@ag-ui/client": "^0.0.51",
    "@ag-ui/core": "^0.0.51",
    "@modelcontextprotocol/ext-apps": "^0.1.0",
    "fast-json-patch": "^3.1.1",
    "marked": "^18.0.0",
    "dompurify": "^3.3.3",
    {%- endif %}
    "@tanstack/svelte-query": "^5.75.0",
    "bits-ui": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ky": "^1.8.1",
    "lucide-svelte": "^0.475.0",
    "svelte-sonner": "^0.3.28",
    "tailwind-merge": "^3.2.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    {%- if include_chat %}
    "@types/dompurify": "^3.2.0",
    {%- endif %}
    {%- if include_openapi %}
    "@hey-api/openapi-ts": "^0.66.0",
    {%- endif %}
    "@playwright/test": "^1.49.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.1.4",
    "@testing-library/svelte": "^5.2.7",
    "eslint": "^9.26.0",
    "eslint-plugin-svelte": "^3.0.0",
    "jsdom": "^26.1.0",
    "msw": "^2.8.4",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.3.3",
    "vitest": "^3.1.2"
  },
  "msw": {
    "workerDirectory": [
      "static"
    ]
  }
}
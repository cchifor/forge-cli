# forge-generated project — top-level editorconfig.
# https://editorconfig.org — override per-language in nested .editorconfig
# files if a specific tool needs different settings.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,vue,svelte,mjs,cjs,json,jsonc,yaml,yml,toml,md}]
indent_size = 2

[*.py]
indent_size = 4

[*.rs]
indent_size = 4

[*.dart]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf

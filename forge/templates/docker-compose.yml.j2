services:
{% for be in backends %}
  # ── Migrations for {{ be.name }} ──
  {{ be.name }}-migrate:
    build:
      context: ./{{ be.name }}
      dockerfile: Dockerfile
    environment:
{% if be.language == "python" %}
      ENV: development
      APP__DB__URL: "postgresql+asyncpg://postgres:postgres@postgres:5432/{{ be.db_name }}"
    command: ["python", "-m", "app", "db", "upgrade"]
{% elif be.language == "node" %}
      DATABASE_URL: "postgresql://postgres:postgres@postgres:5432/{{ be.db_name }}"
    command: ["npx", "prisma", "migrate", "deploy"]
{% elif be.language == "rust" %}
      DATABASE_URL: "postgresql://postgres:postgres@postgres:5432/{{ be.db_name }}"
    command: ["/app/migrate"]
{% endif %}
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - app-network

  # ── {{ be.name }} ──
  {{ be.name }}:
    build:
      context: ./{{ be.name }}
      dockerfile: Dockerfile
    environment:
{% if be.language == "python" %}
      ENV: development
      APP__DB__URL: "postgresql+asyncpg://postgres:postgres@postgres:5432/{{ be.db_name }}"
{% elif be.language == "node" %}
      NODE_ENV: development
      PORT: "{{ be.port }}"
      DATABASE_URL: "postgresql://postgres:postgres@postgres:5432/{{ be.db_name }}"
{% elif be.language == "rust" %}
      PORT: "{{ be.port }}"
      DATABASE_URL: "postgresql://postgres:postgres@postgres:5432/{{ be.db_name }}"
      RUST_LOG: info
{% endif %}
{% if include_keycloak %}
      APP__SECURITY__AUTH__ENABLED: "true"
      APP__SECURITY__AUTH__SERVER_URL: "http://keycloak:8080"
      APP__SECURITY__AUTH__REALM: "{{ keycloak_realm }}"
      APP__SECURITY__AUTH__CLIENT_ID: "{{ keycloak_client_id }}"
{% else %}
      APP__SECURITY__AUTH__ENABLED: "false"
{% endif %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ be.name }}.rule=Host(`app.localhost`) && PathPrefix(`/api/{{ be.name }}`)"
      - "traefik.http.routers.{{ be.name }}.entrypoints=web"
      - "traefik.http.middlewares.{{ be.name }}-rewrite.replacepathregex.regex=^/api/{{ be.name }}/(.*)"
      - "traefik.http.middlewares.{{ be.name }}-rewrite.replacepathregex.replacement=/api/$$1"
{% if include_keycloak %}
      - "traefik.http.routers.{{ be.name }}.middlewares={{ be.name }}-rewrite,auth"
{% else %}
      - "traefik.http.routers.{{ be.name }}.middlewares={{ be.name }}-rewrite"
{% endif %}
      - "traefik.http.services.{{ be.name }}.loadbalancer.server.port={{ be.port }}"
    depends_on:
      {{ be.name }}-migrate:
        condition: service_completed_successfully
{% if include_keycloak %}
      keycloak:
        condition: service_healthy
{% endif %}
    networks:
      - app-network
{% endfor %}

  # ── Database ──
  postgres:
    image: postgres:16-alpine
    ports:
      - "5432:5432"
    environment:
      POSTGRES_DB: {{ db_name }}
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    volumes:
      - pgdata:/var/lib/postgresql/data
{% if backends | length > 1 or include_keycloak %}
      - ./init-db.sh:/docker-entrypoint-initdb.d/init-db.sh
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - app-network

{% if has_frontend %}
  # ── Frontend (nginx — static files + SPA fallback only) ──
  frontend:
    build:
      context: ./{{ frontend_slug }}
      dockerfile: Dockerfile
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.frontend.rule=Host(`app.localhost`)"
      - "traefik.http.routers.frontend.entrypoints=web"
      - "traefik.http.services.frontend.loadbalancer.server.port=80"
    depends_on:
{% for be in backends %}
      - {{ be.name }}
{% endfor %}
    networks:
      - app-network
{% endif %}

  # ── API Gateway ──
  traefik:
    image: traefik:v2.11
    ports:
      - "80:80"
      - "8080:8080"
    environment:
      TRAEFIK_API_INSECURE: "true"
      TRAEFIK_PROVIDERS_DOCKER: "true"
      TRAEFIK_PROVIDERS_DOCKER_EXPOSEDBYDEFAULT: "false"
      TRAEFIK_ENTRYPOINTS_WEB_ADDRESS: ":80"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - app-network

{% if include_keycloak %}
  # ── Auth Gateway (OIDC ForwardAuth) ──
  gatekeeper:
    build:
      context: ./gatekeeper
      dockerfile: Dockerfile
    environment:
      ENV: development
      KEYCLOAK_BASE_URL: "http://keycloak:8080/realms"
      KEYCLOAK_EXTERNAL_URL: "http://localhost:{{ keycloak_port }}/realms"
      GATEKEEPER_CLIENT_ID: gatekeeper
      GATEKEEPER_CLIENT_SECRET: gatekeeper-dev-secret
      COOKIE_NAME: tenant_session
      COOKIE_SECURE: "False"
      REFRESH_COOKIE_NAME: tenant_refresh
      REDIS_URL: "redis://redis:6379"
      DEFAULT_RATE_LIMIT: "600"
    depends_on:
      keycloak:
        condition: service_healthy
      redis:
        condition: service_started
    labels:
      - "traefik.enable=true"
      - "traefik.http.middlewares.auth.forwardauth.address=http://gatekeeper:5000/auth"
      - "traefik.http.middlewares.auth.forwardauth.authResponseHeaders=X-Gatekeeper-User-Id,X-Gatekeeper-Email,X-Gatekeeper-Tenant,X-Gatekeeper-Roles,X-Gatekeeper-Auth-Method,X-RateLimit-Limit,X-RateLimit-Remaining,X-RateLimit-Reset"
      - "traefik.http.middlewares.auth.forwardauth.trustForwardHeader=true"
      - "traefik.http.routers.gatekeeper.rule=PathPrefix(`/callback`) || PathPrefix(`/logout`) || PathPrefix(`/auth/userinfo`) || PathPrefix(`/auth/login`)"
      - "traefik.http.services.gatekeeper.loadbalancer.server.port=5000"
    networks:
      - app-network

  # ── Identity Provider ──
  keycloak:
    build:
      context: ./keycloak
      dockerfile: Dockerfile
    command: start-dev --import-realm
    ports:
      - "{{ keycloak_port }}:8080"
    environment:
      KC_DB: postgres
      KC_DB_URL_HOST: postgres
      KC_DB_URL_DATABASE: keycloak
      KC_DB_USERNAME: postgres
      KC_DB_PASSWORD: postgres
      KC_HEALTH_ENABLED: "true"
      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: admin
    volumes:
      - ./keycloak-realm.json:/opt/keycloak/data/import/realm.json:ro
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "cat < /dev/null > /dev/tcp/localhost/9000"]
      interval: 10s
      timeout: 5s
      retries: 15
      start_period: 30s
    networks:
      - app-network

  # ── Session Cache ──
  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    networks:
      - app-network
{% endif %}

  # ── Tools (optional) ──
  pgadmin:
    image: dpage/pgadmin4:latest
    ports:
      - "5050:80"
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@localhost.com
      PGADMIN_DEFAULT_PASSWORD: admin
    profiles:
      - tools
    networks:
      - app-network

{% if has_frontend %}
  # ── E2E Tests (on-demand: docker compose --profile test run e2e) ──
  e2e:
    build:
      context: ./{{ project_slug }}-e2e
      dockerfile: Dockerfile
    environment:
      BASE_URL: "http://frontend:80"
      CI: "true"
{% if include_keycloak %}
      KEYCLOAK_URL: "http://keycloak:8080"
      KEYCLOAK_REALM: "{{ keycloak_realm }}"
      TEST_USER: "dev@localhost"
      TEST_PASSWORD: "devpass"
{% endif %}
    depends_on:
      - frontend
{% for be in backends %}
      - {{ be.name }}
{% endfor %}
{% if include_keycloak %}
      - gatekeeper
{% endif %}
    networks:
      - app-network
    profiles:
      - test
{% endif %}

volumes:
  pgdata:
{% if include_keycloak %}
  redis_data:
{% endif %}

networks:
  app-network:
    driver: bridge

{
  "realm": "{{ keycloak_realm }}",
  "enabled": true,
  "displayName": "{{ project_name }}",
  "displayNameHtml": "<strong>{{ project_name }}</strong>",
  "sslRequired": "none",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "loginTheme": "vscode",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full administrative access",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "user",
        "description": "Standard user access",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "{{ keycloak_client_id }}",
      "name": "{{ project_name }} Web Application",
      "description": "Public SPA client for the frontend",
      "enabled": true,
      "publicClient": true,
      "clientAuthenticatorType": "client-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:*",
        "http://127.0.0.1:*",
        "http://*.localhost/*"
      ],
      "webOrigins": ["+"],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:*##http://*.localhost/*"
      },
      "protocolMappers": [
        {
          "name": "gatekeeper-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "gatekeeper",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "gatekeeper",
      "name": "Gatekeeper ForwardAuth",
      "description": "Confidential server client for the Gatekeeper auth proxy",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "gatekeeper-dev-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "gatekeeper",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "dev@localhost",
      "email": "dev@localhost",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Dev",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "devpass",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "user"]
    }
  ]
}

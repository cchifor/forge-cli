[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ project_description }}"
requires-python = ">={{ python_version }}"
dependencies = [
    # Web Framework
    "fastapi>=0.115.0",
    "uvicorn>=0.34.0",
    "typer>=0.15.0",
    # Data Validation & Settings
    "pydantic>=2.11.0",
    "pydantic-settings>=2.12.0",
    # Database
    "sqlalchemy>=2.0.40",
    "asyncpg>=0.31.0",
    "aiosqlite>=0.22.0",
    "alembic>=1.18.0",
    # Dependency Injection
    "dishka>=1.8.0",
    # Authentication
    "python-keycloak>=5.3.0",
    "PyJWT>=2.10.0",
    # Service Discovery
    "py-eureka-client>=0.11.0",
    # Configuration
    "PyYAML>=6.0.0",
    "python-dotenv>=1.1.0",
    "deepmerge>=2.0",
    # Observability
    "opentelemetry-api>=1.20.0",
    "opentelemetry-sdk>=1.20.0",
    # HTTP Client (service-to-service)
    "httpx>=0.28.0",
    # Utilities
    "email-validator>=2.2.0",
    "python-multipart>=0.0.20",
    "cachetools>=5.5.0",
]

[dependency-groups]
dev = [
    "pytest>=9.0.2",
    "pytest-asyncio>=1.3.0",
    "pytest-cov>=7.1.0",
    "httpx>=0.28.1",
    "ruff>=0.15.8",
    "mypy>=1.19.1",
    "pre-commit>=3.5.0",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/app", "src/service"]

[tool.pytest.ini_options]
pythonpath = ["src"]
testpaths = ["tests"]
asyncio_mode = "auto"
markers = [
    "slow: marks tests as slow",
    "integration: integration tests",
    "unit: unit tests",
]

[tool.ruff]
target-version = "py313"
line-length = 100
src = ["src", "tests"]

[tool.ruff.lint]
select = ["E", "F", "I", "W"]

[tool.mypy]
python_version = "3.13"
plugins = ["pydantic.mypy"]
ignore_missing_imports = true

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/ui-protocol/workspace_activity.json",
  "title": "WorkspaceActivity",
  "description": "One activity card rendered in the workspace pane. The engine determines which renderer handles the content.",
  "type": "object",
  "properties": {
    "engine": {"type": "string", "enum": ["ag-ui", "mcp-ext"]},
    "activityType": {"type": "string"},
    "messageId": {"type": "string"},
    "content": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": ["engine", "activityType", "messageId", "content"],
  "additionalProperties": false
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Item {
  id          String     @id @default(uuid())
  customer_id String
  user_id     String
  name        String     @db.VarChar(255)
  description String?
  tags        String[]   @default([])
  status      ItemStatus @default(DRAFT)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  @@index([customer_id, name], map: "ix_items_customer_name")
  @@index([customer_id, status], map: "ix_items_customer_status")
  @@map("items")
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model BackgroundTask {
  id           String     @id @default(uuid())
  task_type    String     @db.VarChar(100)
  status       TaskStatus @default(PENDING)
  payload      Json?
  result       Json?
  error        String?
  attempts     Int        @default(0)
  max_retries  Int        @default(3)
  scheduled_at DateTime   @default(now())
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime   @default(now())

  @@index([status, scheduled_at], map: "ix_bg_tasks_status_scheduled")
  @@map("background_tasks")
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String   @db.VarChar(50)
  entity_type String?  @db.VarChar(100)
  entity_id   String?  @db.VarChar(255)
  username    String?  @db.VarChar(255)
  ip_address  String?  @db.VarChar(45)
  user_agent  String?  @db.VarChar(500)
  status_code Int?
  method      String?  @db.VarChar(10)
  path        String?  @db.VarChar(500)
  metadata    Json?    @map("meta_data")
  duration_ms Float?
  created_at  DateTime @default(now())

  @@map("audit_logs")
}

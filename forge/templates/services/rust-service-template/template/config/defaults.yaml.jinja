app:
  name: "{{ project_name }}"
  version: "0.0.0"

server:
  host: "0.0.0.0"
  port: 5000
  cors:
    enabled: true
    allow_origins: ["*"]
    allow_credentials: false
    max_age: 600

db:
  url: "postgresql://postgres:postgres@localhost:5432/{{ project_name }}"
  pool_min: 2
  pool_max: 10
  statement_timeout_ms: 30000

logging:
  level: "info"
  pretty: false

security:
  auth:
    enabled: false

    "uuid": "^11.1.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "@biomejs/biome": "^2.0.0",
    "vitest": "^3.2.3",
    "prisma": "^6.9.0",
